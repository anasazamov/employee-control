# Nusxalash: cp .env.example .env
EC_DEBUG=true
# Runtime — app_user (RLS'ni chetlab o'tolmaydi)
EC_DATABASE_URL=postgresql+asyncpg://app_user:app_password@localhost:5433/employee_control
# Migratsiya/provisioning — superuser
EC_MIGRATIONS_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/employee_control
EC_REDIS_URL=redis://localhost:6380/0
EC_JWT_SECRET=dev-secret-change-me
# MinIO (selfie/foto)
EC_MINIO_ENDPOINT=localhost:9000
EC_MINIO_ACCESS_KEY=minioadmin
EC_MINIO_SECRET_KEY=minioadmin
# Platforma-konsol kaliti
EC_PLATFORM_API_KEY=dev-platform-key-change-me
