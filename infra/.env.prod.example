# Prod/test deploy sozlamalari. Serverda .env.prod ga nusxalab, kuchli qiymatlar qo'ying.
DB_PASSWORD=change-me-strong-db-pass
JWT_SECRET=change-me-32bytes-minimum-secret-000
PLATFORM_API_KEY=change-me-platform-key
MINIO_ACCESS_KEY=ec-minio-admin
MINIO_SECRET_KEY=change-me-minio-secret
# Telefon/API MinIO'ga shu manzil orqali yuklaydi (public IP:port)
MINIO_PUBLIC_ENDPOINT=89.117.49.131:9010
# Yuz-backend: "stub" (yengil, deterministik) yoki "insightface" (haqiqiy, RAM-og'ir)
FACE_BACKEND=stub
FACE_MODEL_PACK=buffalo_s
# Web admin brauzeri uchun CORS origin(lar)i (vergul bilan). Dev-server +
# deploy qilingan admin domeni/porti. Bo'sh = CORS o'chiq (brauzer ulanolmaydi).
CORS_ORIGINS=http://localhost:5173
# Staging/test: DEBUG=true (OTP dev-kodi). Prod: bo'sh qoldiring (=false).
DEBUG=
# insightface o'rnatilsinmi (build arg). Haqiqiy yuz-tanish uchun: true
INSTALL_FACE=true
# api RAM limiti (insightface og'ir; hostni OOM'dan saqlaydi)
API_MEM_LIMIT=2g

# MUHIM: har doim --env-file bilan ishga tushiring, aks holda secretlar bo'sh
# qolib API buziladi (JWT/MinIO/face):
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
